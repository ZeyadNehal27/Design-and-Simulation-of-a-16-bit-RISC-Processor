// program_counter.v Program Counter
// Zeyad Nehal
module program_counter (
    input        clk,
    input        rst,
    input  [4:0] pc_in,
    output reg [4:0] pc_out
);
    always @(posedge clk or posedge rst) begin
        if (rst)
            pc_out <= 5'd0;
        else
            pc_out <= pc_in;
    end
endmodule
